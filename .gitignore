# ---- secrets / env (do NOT commit) ----
bootstrap.env
*.env
.env
.env.*
!*.env.example

# ---- ssh keys (do NOT commit) ----
id_*
*.pem
*.key

# ---- cloudflared credentials (do NOT commit) ----
**/.cloudflared/
**/cloudflared/*.json
/etc/cloudflared/*.json

# ---- runtime data (do NOT commit) ----
**/pg_data/
**/valkey_data/
**/data/
**/backups/
**/caddy_data/
**/caddy_config/

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# ---- Windows ----
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---- Linux / Unix ----
*~
*.swp
*.swo
.nfs*
