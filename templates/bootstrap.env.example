# ============================
# OpenClaw Host Bootstrap Env
# 建议位置：/opt/openclaw/bootstrap.env
# 权限建议：sudo chmod 600 /opt/openclaw/bootstrap.env
# 说明：此文件包含敏感信息，不要提交到 Git
# ============================

# --- 基础身份/系统 ---
ADMIN_USER="op"
TIMEZONE="America/Los_Angeles"
HOSTNAME_FQDN="openclaw-1"
SSH_PORT="22"

# 你的 SSH 公钥（不是私钥）
SSH_PUBKEY="ssh-ed25519 AAAA...REPLACE_ME... openclaw-host"

# --- OpenClaw 目录 ---
OPENCLAW_BASE="/opt/openclaw"

# --- Preflight 控制（Ubuntu 通用）---
PREFLIGHT_STRICT="1"     # 1=关键失败阻断退出；0=仅警告
ALLOW_WEAK_HOST="0"      # 1=允许低规格主机继续（仅测试建议）
MIN_RAM_GB="4"
MIN_CPU_CORES="2"
MIN_DISK_FREE_GB="80"
FORCE_RAM_TIER=""        # 可选：S/M/L/XL

# --- Infra（Postgres + pgvector / Valkey）---
POSTGRES_DB="openclaw"
POSTGRES_USER="openclaw"
POSTGRES_PASSWORD="CHANGE_ME_STRONG"
PGVECTOR_IMAGE="pgvector/pgvector:pg18-trixie"
VALKEY_IMAGE="valkey/valkey:9"

# --- 可选：资源覆盖（默认按 RAM 分档自动选择）---
# SWAP_GB="2"
# POSTGRES_MEM_LIMIT="1100m"
# POSTGRES_SHM_SIZE="256mb"
# VALKEY_MEM_LIMIT="256m"
# VALKEY_MAXMEM="192mb"
# PG_SHARED_BUFFERS="256MB"
# PG_EFFECTIVE_CACHE_SIZE="768MB"
# PG_WORK_MEM="16MB"
# PG_MAINTENANCE_WORK_MEM="128MB"
# PG_MAX_CONNECTIONS="80"

# --- Cloudflare Tunnel（单 Web 后台，无反代）---
CF_RUN_USER="op"
CF_TUNNEL_NAME="openclaw-admin"
CF_HOSTNAME="admin.example.com"
CF_LOCAL_URL="http://127.0.0.1:3000"  # Web 后台务必只监听 127.0.0.1
