# ============================
# OpenClaw Host Bootstrap Env
# Suggested path: /opt/openclaw/bootstrap.env
# Suggested permission: sudo chmod 600 /opt/openclaw/bootstrap.env
# Note: This file contains sensitive data. Do not commit it to Git.
# ============================

# --- Basic identity/system ---
ADMIN_USER="op"
TIMEZONE="America/Los_Angeles"
HOSTNAME_FQDN="openclaw-1"
SSH_PORT="22"

# Your SSH public key (not private key)
SSH_PUBKEY="ssh-ed25519 AAAA...REPLACE_ME... openclaw-host"

# --- OpenClaw paths ---
OPENCLAW_BASE="/opt/openclaw"

# --- Preflight controls (generic Ubuntu) ---
PREFLIGHT_STRICT="1"     # 1=block and exit on critical failures; 0=warn only
ALLOW_WEAK_HOST="0"      # 1=allow low-spec host to continue (testing only)
MIN_RAM_GB="4"
MIN_CPU_CORES="2"
MIN_DISK_FREE_GB="80"
FORCE_RAM_TIER=""        # Optional: S/M/L/XL

# --- Infra（Postgres + pgvector / Valkey）---
POSTGRES_DB="openclaw"
POSTGRES_USER="openclaw"
POSTGRES_PASSWORD="CHANGE_ME_STRONG"
PGVECTOR_IMAGE="pgvector/pgvector:pg18-trixie"
VALKEY_IMAGE="valkey/valkey:9"

# --- Optional resource overrides (defaults auto-selected by RAM tier) ---
# SWAP_GB="2"
# POSTGRES_MEM_LIMIT="1100m"
# POSTGRES_SHM_SIZE="256mb"
# VALKEY_MEM_LIMIT="256m"
# VALKEY_MAXMEM="192mb"
# PG_SHARED_BUFFERS="256MB"
# PG_EFFECTIVE_CACHE_SIZE="768MB"
# PG_WORK_MEM="16MB"
# PG_MAINTENANCE_WORK_MEM="128MB"
# PG_MAX_CONNECTIONS="80"

# --- Cloudflare Tunnel (single web admin endpoint, no reverse proxy) ---
CF_RUN_USER="op"
CF_TUNNEL_NAME="openclaw-admin"
CF_HOSTNAME="admin.example.com"
CF_LOCAL_URL="http://127.0.0.1:3000"  # Web admin must stay bound to 127.0.0.1
